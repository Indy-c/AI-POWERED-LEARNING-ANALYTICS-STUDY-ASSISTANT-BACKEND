APP_NAME=AI Learning Assistant API

# Local database for running backend commands directly from the backend folder
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5434/learning_assistant
JWT_SECRET_KEY=change-this-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# GEMINI API 
GEMINI_API_KEY=your-gemini-api-key

# Supabase Storage
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=documents-dev
